# ─── Configuración de Django ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambiar-por-una-clave-secreta-real-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Para SQLite local: sqlite:///db.sqlite3
# Para PostgreSQL: postgresql://usuario:contraseña@localhost:5432/nombre_bd
DATABASE_URL=sqlite:///db.sqlite3

# ─── Configuración de Celery & Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Configuración de Correo (SMTP) ───────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_de_aplicacion
DEFAULT_FROM_EMAIL=EduFlow <tu_correo@gmail.com>
